# ==================== Environment ====================
ENVIRONMENT=development

# ==================== Database ====================
# Supabase (PostgreSQL) is the primary backend.
# Set DATABASE_URL to your Supabase connection string.
# Example:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
#
# SQLite fallback: leave DATABASE_URL empty to use a local SQLite file.
# The SQLite path defaults to service/server/data/local.db (or set DB_PATH).
DATABASE_URL=

# ==================== API Keys ====================
ALPHA_VANTAGE_API_KEY=demo
# Finnhub free tier (60 calls/min) — fallback for technical analysis when yfinance is rate-limited
FINNHUB_API_KEY=d96p2j1r01qr77dld6qgd96p2j1r01qr77dld6r0
# Optional: enrich US stock market-intel snapshots with Adanos social/news/prediction-market sentiment.
ADANOS_API_KEY=

# ==================== Frontend ====================
# Frontend auto-refresh interval in milliseconds.
VITE_REFRESH_INTERVAL=300000

# ==================== Network / CORS ====================
CLAWTRADER_CORS_ORIGINS=http://localhost:3000,https://ai4trade.ai

# ==================== Market Data Endpoints ====================
ADANOS_API_BASE_URL=https://api.adanos.org
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz/info
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com

# ==================== Background Tasks ====================
POSITION_REFRESH_INTERVAL=300
MAX_PARALLEL_PRICE_FETCH=5
POLYMARKET_SETTLE_INTERVAL=60
MARKET_NEWS_REFRESH_INTERVAL=900
MACRO_SIGNAL_REFRESH_INTERVAL=900
ETF_FLOW_REFRESH_INTERVAL=900
STOCK_ANALYSIS_REFRESH_INTERVAL=1800
ADANOS_SENTIMENT_CACHE_TTL_SECONDS=300
ADANOS_SENTIMENT_TIMEOUT_SECONDS=4

# ==================== Profit History Retention ====================
# Keep recent history at full resolution.
PROFIT_HISTORY_FULL_RESOLUTION_HOURS=24

# Keep compacted history inside this rolling window.
PROFIT_HISTORY_COMPACT_WINDOW_DAYS=7

# Bucket size used when compacting older profit history.
PROFIT_HISTORY_COMPACT_BUCKET_MINUTES=15

# Minimum interval between prune/compact passes.
PROFIT_HISTORY_PRUNE_INTERVAL_SECONDS=3600

# ==================== Agent Trading Budget ====================
# Cap the effective capital agents use for position sizing, without changing
# their actual cash balance in the database. Agents will size trades as if
# they only have this much capital, leaving the rest as idle cash.
# Set to empty or remove to use full portfolio value.
AGENT_TRADE_BUDGET=10000

# ==================== Price Fetch Reliability ====================
PRICE_FETCH_TIMEOUT_SECONDS=10
PRICE_FETCH_MAX_RETRIES=2
PRICE_FETCH_BACKOFF_BASE_SECONDS=0.35
PRICE_FETCH_ERROR_COOLDOWN_SECONDS=20
PRICE_FETCH_RATE_LIMIT_COOLDOWN_SECONDS=60
